# Discord bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# API-Football key from https://dashboard.api-football.com
API_FOOTBALL_KEY=your_api_football_key_here

# Target channel ID (right-click channel → Copy Channel ID, needs Developer Mode on)
DISCORD_CHANNEL_ID=your_channel_id_here

# Cron expression for when to post polls (default: 8:00 AM every day)
POST_TIME=0 8 * * *

# Timezone for cron scheduling and match time display
TIMEZONE=Europe/Budapest

# Set to "true" to post a message when no matches are scheduled today
POST_NO_MATCHES=false
